{
  "name": "encode-cli-lint",
  "version": "0.0.32",
  "description": "前端编码规范工程化脚手架",
  "type": "commonjs",
  "bin": "./lib/cli.js",
  "main": "./lib/index.js",
  "scripts": {
    "dev": "npm run copyfiles && tsc -w",
    "build": "rimraf lib && npm run copyfiles && tsc",
    "copyfiles": "copyfiles -a -u 1 \"src/config/**\" lib",
    "build1": "rimraf lib && encode-bundle src/index.ts --format iife,cjs,esm --dts --minify --global-name encodeMonitor --outDir lib",
    "test": "npm run build && jest",
    "coverage": "nyc jest --silent --forceExit",
    "encode-spec-clilint-scan": "encode-spec-clilint scan",
    "encode-spec-clilint-fix": "encode-spec-clilint fix"
  },
  "files": [
    "lib/"
  ],
  "engines": {
    "node": "^12.22.0 || ^14.17.0 || >=16.0.0"
  },
  "keywords": [
    "encode",
    "lint",
    "cli"
  ],
  "devDependencies": {
    "@swc/core": "^1.12.9",
    "@types/command-exists": "^1.2.0",
    "@types/cross-spawn": "^6.0.2",
    "@types/ejs": "^3.1.0",
    "@types/eslint": "^8.4.1",
    "@types/fs-extra": "^9.0.13",
    "@types/glob": "^7.2.0",
    "@types/lodash": "^4.14.180",
    "@types/node": "^14.14.11",
    "@types/prettier": "^2.4.4",
    "@types/stylelint": "^14.0.0",
    "@types/text-table": "^0.2.2",
    "copyfiles": "^2.4.1",
    "encode-bundle": "^1.4.1",
    "jest": "^27.5.1",
    "nyc": "^15.1.0",
    "rimraf": "^3.0.2",
    "typescript": "^4.6.2"
  },
  "dependencies": {
    "@babel/core": "^7.16.0",
    "@babel/eslint-parser": "^7.16.3",
    "@babel/preset-react": "^7.16.0",
    "@commitlint/cli": "^16.0.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "chalk": "^4.1.0",
    "command-exists": "^1.2.9",
    "commander": "^6.2.1",
    "cross-spawn": "^7.0.3",
    "ejs": "^3.1.5",
    "encode-commitlint-config": "^0.0.25",
    "encode-eslint-config": "^0.0.25",
    "encode-eslint-plugin": "^0.0.25",
    "encode-markdownlint-config": "^0.0.25",
    "encode-stylelint-config": "^0.0.25",
    "eslint": "^8.7.0",
    "eslint-config-egg": "^10.0.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-vue": "^7.3.0",
    "execa": "^5.0.0",
    "fast-glob": "^3.2.11",
    "fs-extra": "^9.0.1",
    "glob": "^7.1.6",
    "husky": "^3.1.0",
    "inquirer": "^7.3.3",
    "is-docker": "^2.1.1",
    "lodash": "^4.17.20",
    "markdownlint": "^0.25.1",
